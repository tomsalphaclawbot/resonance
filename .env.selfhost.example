# Resonance self-host profile
# Copy to .env.selfhost and fill values before running docker-compose.selfhost.yml

# --- App runtime ---
NODE_ENV=development
APP_URL=http://localhost:3000
SELFHOST_MODE=true
PORT=3000

# --- Database (self-hosted Postgres) ---
DATABASE_URL=postgresql://resonance:resonance@postgres:5432/resonance

# --- Object storage (MinIO / S3-compatible) ---
# Keep existing R2 names for current code compatibility.
R2_ACCOUNT_ID=minio-local
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=resonance-audio

# Optional forward-compatible S3 settings for code abstraction phase
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# --- Inference API (self-hosted chatterbox-compatible endpoint) ---
CHATTERBOX_API_URL=http://chatterbox:8000
CHATTERBOX_API_KEY=change-me

# --- Billing (existing Polar integration; replace in Phase 2) ---
POLAR_ACCESS_TOKEN=replace-with-local-billing-token-or-dummy
POLAR_SERVER=sandbox
POLAR_PRODUCT_ID=replace-with-local-product-id

# --- Auth (current Clerk integration; replace in Phase 2) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Observability (make env-driven before Phase 3 cutover) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=selfhost
SENTRY_TRACES_SAMPLE_RATE=1.0

# --- MinIO bootstrap credentials (compose service vars) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
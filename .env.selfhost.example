# Resonance self-host profile
# Copy to .env.selfhost and run docker-compose.selfhost.yml

# --- App runtime ---
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000
SELFHOST_MODE=true
NEXT_PUBLIC_SELFHOST_MODE=true
DISABLE_AUTH=true
DISABLE_BILLING=true
SKIP_ENV_VALIDATION=false

# --- Database (self-hosted Postgres) ---
DATABASE_URL=postgresql://resonance:resonance@postgres:5432/resonance

# --- Optional storage/inference placeholders (required by current code paths) ---
# These defaults allow app bootstrap even when local object storage / inference
# are not started yet. Replace with real endpoints in later phases.
R2_ACCOUNT_ID=selfhost-local
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=resonance-audio
S3_ENDPOINT=http://minio:9000
S3_FORCE_PATH_STYLE=true
CHATTERBOX_API_URL=http://host.docker.internal:8000
CHATTERBOX_API_KEY=selfhost-local

# --- Optional cloud-compatible settings (only needed if enabling providers) ---
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox
POLAR_PRODUCT_ID=selfhost-default-product
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Observability ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=selfhost
SENTRY_TRACES_SAMPLE_RATE=0
